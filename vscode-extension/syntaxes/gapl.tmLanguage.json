{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GAPL",
  "scopeName": "source.gapl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-call" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gapl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.gapl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gapl",
          "match": "\\b(if|else)\\b"
        },
        {
          "name": "storage.type.gapl",
          "match": "\\b(interface|function|wire|integer)\\b"
        },
        {
          "name": "keyword.other.gapl",
          "match": "\\b(declare|in|out|inout)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.gapl",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.gapl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.gapl",
          "match": "=>|==|!=|>=|<=|&&|\\|\\||[+\\-*/%]"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.gapl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}
