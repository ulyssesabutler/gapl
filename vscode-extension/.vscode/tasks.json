{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build extension + language server",
      "type": "shell",
      "command": "./gradlew",
      "args": [":vscode-extension:assemble"],
      "options": {
        "cwd": "${workspaceFolder}/.."
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
