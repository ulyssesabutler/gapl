interface aes_block_item wire[8]
interface aes_block_column aes_block_item[4]
interface aes_block aes_block_column[4]

function to_aes_block() i: wire[128] => o: aes_block
{
    i => vector_chunk(wire, 8, 16)
      => vector_chunk(aes_block_item, 4, 4)
      => o;
}

function from_aes_block() i: aes_block => o: wire[128]
{
    i => vector_flatten(aes_block_item, 4, 4)
      => vector_flatten(wire, 8, 16)
      => o;
}

function rotate_word() i: aes_block_column => o: aes_block_column
{
    i[3]   => o[0];
    i[0:2] => o[1:3];
}

function rotate_word_by(factor: integer) i: aes_block_column => o: aes_block_column
{
    i => repeat(aes_block_column, factor, rotate_word()) => o;
}

function substitute_word(substitution: aes_block_item => aes_block_item) i: aes_block_column => o: aes_block_column
{
    i => vector_map(aes_block_item, aes_block_item, 4, substitution) => o;
}

function substitute_block(substitution: aes_block_item => aes_block_item) i: aes_block => o: aes_block
{
    i => vector_map(aes_block_column, aes_block_column, 4, substitute_word(substitution)) => o;
}

function word_addition() i1: aes_block_column, i2: aes_block_column => o: aes_block_column
{
    i1, i2 => vector_zip(aes_block_item, aes_block_item, 4)
           => vector_map(pair(aes_block_item, aes_block_item), aes_block_item, 4, unpair(aes_block_item, aes_block_item, aes_block_item, bitwise_xor(8)))
           => o;
}

function block_addition() i1: aes_block, i2: aes_block => o: aes_block
{
    i1, i2 => vector_zip(aes_block_column, aes_block_column, 4)
           => vector_map(pair(aes_block_column, aes_block_column), aes_block_column, 4, unpair(aes_block_column, aes_block_column, aes_block_column, word_addition()))
           => o;
}

function round_key(round_number: integer) previous_key: aes_block => current_key: aes_block
{
    if (round_number == 0) {
        // On the first round, use the user-provided key directly
        previous_key => current_key;
    } else {
        previous_key[0] => declare rotate_word_node: rotate_word()
                        => declare substitute_word_node: substitute_word(s_box())
                        => declare transformed_last_column: aes_block_column;

        declare round_constant_node: round_constant(round_number - 1) => declare current_round_constant: aes_block_column;

        transformed_last_column, current_round_constant => word_addition() => declare last_column_with_round_constant: aes_block_column;

        declare updated_key: aes_block;

        last_column_with_round_constant, previous_key[3] => word_addition() => updated_key[3];

        updated_key[1:3], previous_key[0:2]
            => vector_zip(aes_block_column, aes_block_column, 3)
            => vector_map(pair(aes_block_column, aes_block_column), aes_block_column, 3, unpair(aes_block_column, aes_block_column, aes_block_column, word_addition()))
            => updated_key[0:2];

        updated_key => current_key;
    }
}

function transpose() i: aes_block => o: aes_block
{
    // Doing this recursively is hard
    i[0][0] => o[0][0];
    i[1][0] => o[0][1];
    i[2][0] => o[0][2];
    i[3][0] => o[0][3];
    i[0][1] => o[1][0];
    i[1][1] => o[1][1];
    i[2][1] => o[1][2];
    i[3][1] => o[1][3];
    i[0][2] => o[2][0];
    i[1][2] => o[2][1];
    i[2][2] => o[2][2];
    i[3][2] => o[2][3];
    i[0][3] => o[3][0];
    i[1][3] => o[3][1];
    i[2][3] => o[3][2];
    i[3][3] => o[3][3];
}

function rotate_rows() i: aes_block => o: aes_block
{
    i => transpose() => declare transposed: aes_block;

    declare shifted: aes_block;

    transposed[3]                      => shifted[3];
    transposed[2] => rotate_word_by(1) => shifted[2];
    transposed[1] => rotate_word_by(2) => shifted[1];
    transposed[0] => rotate_word_by(3) => shifted[0];

    shifted => transpose() => o;
}

// Full multiplication isn't actually needed for AES. Only the constants 2 and 3 are used for encryption.
function gf_multiply_2() i: aes_block_item => o: aes_block_item
{
    i, literal(8, 1) => left_shift(8) => declare shifted: aes_block_item;

    i[7] => replicate(wire, 8) => declare mask: aes_block_item;
    literal(8, 27), mask => bitwise_and(8) => declare optional_constant: aes_block_item;

    shifted, optional_constant => bitwise_xor(8) => o;
}

function gf_multiply_3() i: aes_block_item => o: aes_block_item
{
    i => gf_multiply_2() => declare doubled: aes_block_item;
    doubled, i => bitwise_xor(8) => o;
}

function byte_addition_4() i1: aes_block_item, i2: aes_block_item, i3: aes_block_item, i4: aes_block_item => o: aes_block_item
{
    i1, i2 => bitwise_xor(8) => declare first_half: aes_block_item;
    i3, i4 => bitwise_xor(8) => declare second_half: aes_block_item;
    first_half, second_half => bitwise_xor(8) => o;
}

function mix_column() column: aes_block_column => o: aes_block_column
{
    column[3] => gf_multiply_2() => declare i00: aes_block_item;
    column[2] => gf_multiply_3() => declare i01: aes_block_item;
    column[1] =>                    declare i02: aes_block_item;
    column[0] =>                    declare i03: aes_block_item;
    i00, i01, i02, i03 => byte_addition_4() => o[3];

    column[3] =>                    declare i10: aes_block_item;
    column[2] => gf_multiply_2() => declare i11: aes_block_item;
    column[1] => gf_multiply_3() => declare i12: aes_block_item;
    column[0] =>                    declare i13: aes_block_item;
    i10, i11, i12, i13 => byte_addition_4() => o[2];

    column[3] =>                    declare i20: aes_block_item;
    column[2] =>                    declare i21: aes_block_item;
    column[1] => gf_multiply_2() => declare i22: aes_block_item;
    column[0] => gf_multiply_3() => declare i23: aes_block_item;
    i20, i21, i22, i23 => byte_addition_4() => o[1];

    column[3] => gf_multiply_3() => declare i30: aes_block_item;
    column[2] =>                    declare i31: aes_block_item;
    column[1] =>                    declare i32: aes_block_item;
    column[0] => gf_multiply_2() => declare i33: aes_block_item;
    i30, i31, i32, i33 => byte_addition_4() => o[0];
}


function mix_columns() i: aes_block => o: aes_block
{
    i[0] => mix_column() => o[0];
    i[1] => mix_column() => o[1];
    i[2] => mix_column() => o[2];
    i[3] => mix_column() => o[3];
}

function aes_encrypt_round(round_number: integer) i: aes_block, previous_round_key: aes_block => o: aes_block, current_round_key: aes_block
{
    declare block: aes_block;

    if (round_number > 0) {
        i => declare substitute_block_node: substitute_block(s_box())
          => declare rotate_rows_node: rotate_rows()
          => declare unmixed_block: aes_block;

        if (round_number != 10) {
            unmixed_block => declare mix_columns_node: mix_columns() => block;
        } else {
            unmixed_block => block;
        }
    } else {
        i => block;
    }

    previous_round_key => declare round_key_node: round_key(round_number) => declare round_key_block: aes_block;
    block, round_key_block => declare block_addition_node: block_addition() => o;
    round_key_block => current_round_key;
}

function aes_encrypt_from_round(from_round_number: integer) i: aes_block, key: aes_block => o: aes_block
{
    declare after_round_key: aes_block;
    declare after_round_body: aes_block;

    i, key => declare aes_encrypt_round_current: aes_encrypt_round(from_round_number) => after_round_body, after_round_key;

    if (from_round_number < 10) {
        after_round_body, after_round_key => declare aes_encrypt_round_recursive: aes_encrypt_from_round(from_round_number + 1) => o;
    } else {
        after_round_body => o;
    }
}

/*
function aes_encrypt_block() i: aes_block, key: aes_block => o: aes_block
{
    i, key => declare aes_encrypt_from_round_0_node: aes_encrypt_from_round(0) => o;
}
*/

/*
function abridged_aes_encrypt_block() i: aes_block, key: aes_block => o: aes_block
{
    declare output_key: aes_block;

    i, key
        => declare aes_encrypt_round_0:  aes_encrypt_round(0)
        => declare aes_encrypt_round_1:  aes_encrypt_round(1)
        => declare aes_encrypt_round_10: aes_encrypt_round(10)
        => o, output_key;
}
*/

function single_round_aes_encrypt_block() i: aes_block, key: aes_block => o: aes_block
{
    i => declare substitute_block_node: substitute_block(s_box())
      => declare rotate_rows_node: rotate_rows()
      => declare mix_columns_node: mix_columns()
      => o;
}

function aes_encrypt() i: wire[128], key: wire[128] => o: wire[128]
{
    i => declare i_to_aes_block_node: to_aes_block() => declare i_block: aes_block;
    key => declare key_to_aes_block_node: to_aes_block() => declare key_block: aes_block;
    declare o_block: aes_block => declare o_from_aes_block_node: from_aes_block() => o;

    i_block, key_block
        => declare aes_encrypt_block_node: single_round_aes_encrypt_block()
        => o_block;
}

function reverse_byte_order() i: wire[256] => o: wire[256] {
    i => vector_chunk(wire, 8, 32)
      => reverse(wire[8], 32)
      => vector_flatten(wire, 8, 32)
      => o;
}

/* NETFPGA PACKET BODY PROCESSOR */

interface netfpga_packet_body {
    data: wire[256];
    keep: boolean[32];
    valid: boolean;
    last: boolean;
}

function packet_body_processor() i: netfpga_packet_body => o: netfpga_packet_body {
    literal(128, 0) => declare key: wire[128];

    declare encrypt_1_input:  wire[128];
    declare encrypt_1_output: wire[128];
    encrypt_1_input, key => declare aes_encrypt_1_node: aes_encrypt() => encrypt_1_output;

    declare encrypt_2_input:  wire[128];
    declare encrypt_2_output: wire[128];
    encrypt_2_input, key => declare aes_encrypt_2_node: aes_encrypt() => encrypt_2_output;

    declare input_register: register(netfpga_packet_body);
    declare output_register: register(netfpga_packet_body);

    i => input_register;
    output_register => o;

    input_register.data[0:127]   => encrypt_1_input;
    input_register.data[128:255] => encrypt_2_input;

    encrypt_1_output => output_register.data[0:127];
    encrypt_2_output => output_register.data[128:255];

    input_register.keep  => output_register.keep;
    input_register.valid => output_register.valid;
    input_register.last  => output_register.last;
}

/*
function packet_body_processor() i: netfpga_packet_body => o: netfpga_packet_body {
    literal(128, 0) => declare key: wire[128];

    declare encrypt_1_input:  wire[128];
    declare encrypt_1_output: wire[128];
    encrypt_1_input, key => declare aes_encrypt_1_node: aes_encrypt() => encrypt_1_output;

    declare encrypt_2_input:  wire[128];
    declare encrypt_2_output: wire[128];
