    declare input_register: register(netfpga_packet_body);
    declare output_register: register(netfpga_packet_body);

    i => input_register;
    output_register => o;

    input_register.data => declare reverse_input_data: reverse_byte_order();
    declare reverse_output_data: reverse_byte_order() => output_register.data;

    reverse_input_data[0:127] => encrypt_1_input;
    reverse_input_data[128:255] => encrypt_2_input;

    encrypt_1_output => reverse_output_data[0:127];
    encrypt_2_output => reverse_output_data[128:255];

    input_register.keep  => output_register.keep;
    input_register.valid => output_register.valid;
    input_register.last  => output_register.last;
}
*/

function round_constant(round_number: integer) null => o: aes_block_column
{
    if (round_number == 0) {
        literal(8,   1) => o[3];
    } else if (round_number == 1) {
        literal(8,   2) => o[3];
    } else if (round_number == 2) {
        literal(8,   4) => o[3];
    } else if (round_number == 3) {
        literal(8,   8) => o[3];
    } else if (round_number == 4) {
        literal(8,  16) => o[3];
    } else if (round_number == 5) {
        literal(8,  32) => o[3];
    } else if (round_number == 6) {
        literal(8,  64) => o[3];
    } else if (round_number == 7) {
        literal(8, 128) => o[3];
    } else if (round_number == 8) {
        literal(8,  27) => o[3];
    } else if (round_number == 9) {
        literal(8,  54) => o[3];
    }

    literal(8, 0) => o[0];
    literal(8, 0) => o[1];
    literal(8, 0) => o[2];
}

